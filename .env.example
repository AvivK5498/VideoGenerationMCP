# Required
PIAPI_KEY=your_piapi_key_here          # sent as x-api-key (Kling + Seedance)
ELEVENLABS_KEY=your_elevenlabs_key      # sent as xi-api-key (TTS)

# Hebrew transliteration LLM — local LMStudio first, OpenRouter fallback.
OPENROUTER_API_KEY=your_openrouter_key   # fallback only; used if LMStudio is unreachable

# Optional (defaults shown)
# PIAPI_BASE=https://api.piapi.ai/api/v1
# ELEVENLABS_BASE=https://api.elevenlabs.io/v1
# TMPFILES_UPLOAD_URL=https://tmpfiles.org/api/v1/upload
# POLL_INTERVAL_S=5
# POLL_TIMEOUT_S=1800
# FFMPEG_BIN=ffmpeg
# LOG_LEVEL=INFO
# PIAPI_HTTP_TIMEOUT_S=2400   # per-request PiAPI timeout (slow peak-hour submits)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=google/gemma-4-e4b
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# TRANSLITERATE_MAX_TOKENS=512
# TRANSLITERATE_TIMEOUT_S=60
# TRANSLITERATE_PRIMARY=openrouter            # or "lmstudio" (offline)
# TRANSLITERATE_OPENROUTER_MODEL=google/gemini-3.5-flash
